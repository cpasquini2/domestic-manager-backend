# Porta del server
PORT=3000

# Firebase Service Account (JSON key)
# Incolla qui il contenuto del file JSON della service account
FIREBASE_SERVICE_ACCOUNT='{"type":"service_account","project_id":"domestic-manager-ec0a0",...}'

# Oppure usa il path al file
# FIREBASE_SERVICE_ACCOUNT_PATH=./service-account-key.json

# Timezone per cron job
CRON_TIMEZONE=Europe/Rome

# Log level
LOG_LEVEL=info
